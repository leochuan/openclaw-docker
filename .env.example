# OpenClaw Docker environment variables
# Copy to .env and fill in your config
#
# Windows example: OPENCLAW_CONFIG_DIR=C:/Users/yourname/.openclaw
# macOS example:   OPENCLAW_CONFIG_DIR=/Users/yourname/.openclaw
# Relative paths also work: OPENCLAW_CONFIG_DIR=./openclaw-data/config

# Data directories (persistent storage, use absolute paths per platform)
OPENCLAW_CONFIG_DIR=./openclaw-data/config
OPENCLAW_WORKSPACE_DIR=./openclaw-data/workspace

# Gateway ports
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Gateway bind mode (lan / loopback)
OPENCLAW_GATEWAY_BIND=lan

# Gateway access token (generate with one of the commands below)
# Linux/macOS: openssl rand -hex 32
# PowerShell:  -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) })
OPENCLAW_GATEWAY_TOKEN=

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Proxy settings (leave empty if not needed)
# Example: http://host.docker.internal:10808
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,host.docker.internal
